# HoopUp environment variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
#
# IMPORTANT: anything prefixed VITE_ is shipped in the browser bundle.
# Never put secrets here. The Supabase anon key is intentionally public;
# the service_role key MUST NEVER appear in any VITE_ variable.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key — safe to ship to the client
VITE_SUPABASE_ANON_KEY=
